        {
          "name": "GET /admin/stats — No auth (401/422)",
          "request": { "method": "GET", "url": "{{base_url}}/admin/stats" },
          "event": [{"listen":"test","script":{"exec":["pm.test('Rejects', () => pm.expect([401,422]).to.include(pm.response.code));"]}}]
        },
        {
          "name": "GET /admin/config — No auth (401/422)",
          "request": { "method": "GET", "url": "{{base_url}}/admin/config" },
          "event": [{"listen":"test","script":{"exec":["pm.test('Rejects', () => pm.expect([401,422]).to.include(pm.response.code));"]}}]
        }
      ]
    },
    {
      "name": "Face Ops — API Key Required",
      "item": [
        {
          "name": "POST /faces/register — No key (401/422)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/faces/register", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"external_user_id\":\"usr_test\",\"image\":\"dGVzdA==\"}"} },
          "event": [{"listen":"test","script":{"exec":["pm.test('Rejects', () => pm.expect([401,422]).to.include(pm.response.code));"]}}]
        },
        {
          "name": "POST /faces/authenticate — No key (401/422)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/faces/authenticate", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"external_user_id\":\"usr_test\",\"image\":\"dGVzdA==\"}"} },
          "event": [{"listen":"test","script":{"exec":["pm.test('Rejects', () => pm.expect([401,422]).to.include(pm.response.code));"]}}]
        },
        {
          "name": "GET /faces — No key (401/422)",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/faces" },
          "event": [{"listen":"test","script":{"exec":["pm.test('Rejects', () => pm.expect([401,422]).to.include(pm.response.code));"]}}]
        },
        {
          "name": "POST /client-logs — No key (401/422)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/client-logs", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"message\":\"test\"}"} },
          "event": [{"listen":"test","script":{"exec":["pm.test('Rejects', () => pm.expect([401,422]).to.include(pm.response.code));"]}}]
