{
  "info": {
    "name": "Spectre API v1",
    "_postman_id": "spectre-api-v1-collection",
    "description": "Full API validation suite for Spectre (39 endpoints). Works against local and HF Spaces.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "auth_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "app_id", "value": "" },
    { "key": "api_key", "value": "" },
    { "key": "test_email", "value": "newman_test@spectre.dev" },
    { "key": "test_password", "value": "NewmanTest123!" },
    { "key": "admin_email", "value": "admin@spectre.dev" },
    { "key": "admin_password", "value": "Spectre@Admin123" }
  ],
  "item": [
    {
      "name": "Bootstrap — Admin Login",
      "item": [
        {
          "name": "POST /auth/login — Get admin token",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/auth/login", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"email\":\"{{admin_email}}\",\"password\":\"{{admin_password}}\"}"} },
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.response.code === 200) {",
            "  const body = pm.response.json();",
            "  if (body.access_token) {",
            "    pm.collectionVariables.set('auth_token', body.access_token);",
            "    pm.test('Admin token captured', () => pm.expect(body.access_token).to.be.a('string'));",
            "  }",
            "  if (body.refresh_token) {",
            "    pm.collectionVariables.set('refresh_token', body.refresh_token);",
            "  }",
            "} else {",
            "  pm.test('Admin login failed (non-200) — admin tests will be skipped', () => true);",
            "}"
          ]}}]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "GET / — Root HTML",
          "request": { "method": "GET", "url": "{{base_url}}/" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Returns HTML', () => pm.expect(pm.response.headers.get('content-type')).to.include('html'));"
          ]}}]
        },
        {
          "name": "GET /health — Component status",
          "request": { "method": "GET", "url": "{{base_url}}/health" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has components', () => pm.expect(pm.response.json()).to.have.property('components'));",
            "pm.test('Service is spectre-api', () => pm.expect(pm.response.json().service).to.eql('spectre-api'));",
            "pm.test('DB healthy', () => pm.expect(pm.response.json().components.database).to.eql('healthy'));",
            "pm.test('Redis healthy', () => pm.expect(pm.response.json().components.redis).to.eql('healthy'));",
            "pm.test('ML loaded', () => pm.expect(pm.response.json().components.ml_model).to.eql('loaded'));",
            "pm.test('FAS registry present', () => pm.expect(pm.response.json().components.fas_registry).to.include('models'));"
          ]}}]
        },
        {
          "name": "GET /health/ml-status — Active ML model (public)",
          "request": { "method": "GET", "url": "{{base_url}}/health/ml-status" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('Has active_model_id', () => pm.expect(body).to.have.property('active_model_id'));",
            "pm.test('Has active_model object', () => pm.expect(body).to.have.property('active_model'));",
            "if (body.active_model) {",
            "  pm.test('Model has model_id', () => pm.expect(body.active_model).to.have.property('model_id'));",
            "  pm.test('Model has version', () => pm.expect(body.active_model).to.have.property('version'));",
            "  pm.test('Model has supports_tta', () => pm.expect(body.active_model).to.have.property('supports_tta'));",
            "}"
          ]}}]
        }
      ]
    },
    {
      "name": "Auth — Validation",
      "item": [
        {
          "name": "POST /auth/register — Missing email (422)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/auth/register", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"password\":\"Test1234!\"}"} },
          "event": [{"listen":"test","script":{"exec":["pm.test('422', () => pm.response.to.have.status(422));"]}}]
        },
        {
          "name": "POST /auth/register — Missing password (422)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/auth/register", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"email\":\"test@example.com\"}"} },
          "event": [{"listen":"test","script":{"exec":["pm.test('422', () => pm.response.to.have.status(422));"]}}]
        },
        {
          "name": "POST /auth/login — Empty body (422)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/auth/login", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{}"} },
          "event": [{"listen":"test","script":{"exec":["pm.test('422', () => pm.response.to.have.status(422));"]}}]
        },
        {
          "name": "POST /auth/login — Invalid credentials (401)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/auth/login", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"email\":\"nonexist@x.com\",\"password\":\"wrong\"}"} },
          "event": [{"listen":"test","script":{"exec":["pm.test('401', () => pm.response.to.have.status(401));"]}}]
        },
        {
          "name": "POST /auth/refresh — Invalid token (401)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/auth/refresh", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"refresh_token\":\"invalid\"}"} },
          "event": [{"listen":"test","script":{"exec":["pm.test('401', () => pm.response.to.have.status(401));"]}}]
        }
      ]
    },
    {
      "name": "Auth — Protection (No Token)",
      "item": [
        {
          "name": "GET /applications — No auth (401/422)",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/applications" },
          "event": [{"listen":"test","script":{"exec":["pm.test('Rejects', () => pm.expect([401,422]).to.include(pm.response.code));"]}}]
        },
        {
          "name": "POST /applications — No auth (401/422)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/applications", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"name\":\"Test\"}"} },
