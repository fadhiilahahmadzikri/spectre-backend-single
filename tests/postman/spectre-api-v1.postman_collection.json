    {
      "name": "Face Ops — With API Key",
      "item": [
        {
          "name": "GET /faces — List profiles",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/faces", "header": [{"key":"X-API-Key","value":"{{api_key}}"}] },
          "event": [{"listen":"test","script":{"exec":[
            "pm.test('200', () => pm.response.to.have.status(200));",
            "pm.test('Has profiles array', () => pm.expect(pm.response.json()).to.have.property('profiles'));",
            "pm.test('Has count', () => pm.expect(pm.response.json()).to.have.property('count'));"
          ]}}]
        },
        {
          "name": "POST /faces/register — Invalid image (400)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/faces/register", "header": [{"key":"Content-Type","value":"application/json"},{"key":"X-API-Key","value":"{{api_key}}"}], "body": {"mode":"raw","raw":"{\"external_user_id\":\"newman_user\",\"image\":\"bm90X2FfcmVhbF9pbWFnZQ==\"}"} },
          "event": [{"listen":"test","script":{"exec":[
            "pm.test('Key accepted (not 401)', () => pm.expect(pm.response.code).to.not.eql(401));",
            "pm.test('Rejects bad image', () => pm.expect([400,422,500]).to.include(pm.response.code));"
          ]}}]
        },
        {
          "name": "POST /faces/authenticate — Invalid image (400)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/faces/authenticate", "header": [{"key":"Content-Type","value":"application/json"},{"key":"X-API-Key","value":"{{api_key}}"}], "body": {"mode":"raw","raw":"{\"external_user_id\":\"newman_user\",\"image\":\"bm90X2FfcmVhbF9pbWFnZQ==\"}"} },
          "event": [{"listen":"test","script":{"exec":[
            "pm.test('Key accepted (not 401)', () => pm.expect(pm.response.code).to.not.eql(401));",
            "pm.test('Rejects bad image', () => pm.expect([400,404,422,500]).to.include(pm.response.code));"
          ]}}]
        },
        {
          "name": "DELETE /faces/{user} — Not found (404)",
          "request": { "method": "DELETE", "url": "{{base_url}}/api/v1/faces/nonexistent_user_xyz", "header": [{"key":"X-API-Key","value":"{{api_key}}"}] },
          "event": [{"listen":"test","script":{"exec":["pm.test('404', () => pm.response.to.have.status(404));"]}}]
        },
        {
          "name": "GET /sessions/{id} — Not found (404)",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/sessions/00000000-0000-0000-0000-000000000000", "header": [{"key":"X-API-Key","value":"{{api_key}}"}] },
          "event": [{"listen":"test","script":{"exec":["pm.test('404', () => pm.response.to.have.status(404));"]}}]
        },
        {
          "name": "POST /client-logs — Valid telemetry",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/client-logs", "header": [{"key":"Content-Type","value":"application/json"},{"key":"X-API-Key","value":"{{api_key}}"}], "body": {"mode":"raw","raw":"{\"level\":\"info\",\"message\":\"Newman test log\",\"source\":\"newman\"}"} },
          "event": [{"listen":"test","script":{"exec":["pm.test('202', () => pm.response.to.have.status(202));"]}}]
        },
        {
          "name": "POST /faces/benchmark — Without benchmark enabled (403)",
          "request": { "method": "POST", "url": "{{base_url}}/api/v1/faces/benchmark", "header": [{"key":"Content-Type","value":"application/json"},{"key":"X-API-Key","value":"{{api_key}}"}], "body": {"mode":"raw","raw":"{\"image\":\"dGVzdA==\"}"} },
          "event": [{"listen":"test","script":{"exec":[
            "pm.test('Benchmark disabled returns 403', () => pm.expect([400,403,422]).to.include(pm.response.code));",
            "if (pm.response.code === 403) {",
            "  pm.test('Has BENCHMARK_DISABLED code', () => pm.expect(pm.response.json().detail.error_code).to.eql('BENCHMARK_DISABLED'));",
            "}"
          ]}}]
        }
      ]
    },
    {
      "name": "OAuth",
      "item": [
        {
          "name": "GET /auth/oauth/google — Redirect",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/auth/oauth/google" },
          "event": [{"listen":"test","script":{"exec":["pm.test('Redirects or 200', () => pm.expect([200,302,307]).to.include(pm.response.code));"]}}]
        }
      ]
    },
    {
      "name": "Admin — Config",
      "item": [
        {
          "name": "GET /admin/config — With auth",
          "request": { "method": "GET", "url": "{{base_url}}/admin/config", "header": [{"key":"Authorization","value":"Bearer {{auth_token}}"}] },
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.variables.get('auth_token')) {",
            "  pm.test('200 or 403', () => pm.expect([200,403]).to.include(pm.response.code));",
            "  if (pm.response.code === 200) {",
            "    pm.test('Has categories', () => pm.expect(pm.response.json()).to.have.property('categories'));",
            "    pm.test('Has anti_spoofing category', () => pm.expect(pm.response.json().categories).to.have.property('anti_spoofing'));",
            "    const items = pm.response.json().categories.anti_spoofing || [];",
            "    const keys = items.map(i => i.key);",
            "    pm.test('Has active_fas_model config', () => pm.expect(keys).to.include('active_fas_model'));",
            "  }",
            "} else { pm.test('Skipped (no token)', () => true); }"
          ]}}]
        },
        {
          "name": "GET /admin/fas-models — List FAS models",
          "request": { "method": "GET", "url": "{{base_url}}/admin/fas-models", "header": [{"key":"Authorization","value":"Bearer {{auth_token}}"}] },
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.variables.get('auth_token')) {",
            "  pm.test('200 or 403', () => pm.expect([200,403]).to.include(pm.response.code));",
            "  if (pm.response.code === 200) {",
            "    const body = pm.response.json();",
            "    pm.test('Has active_model_id', () => pm.expect(body).to.have.property('active_model_id'));",
            "    pm.test('Has models array', () => pm.expect(body).to.have.property('models'));",
            "    pm.test('Has loaded_count', () => pm.expect(body).to.have.property('loaded_count'));",
            "    pm.test('At least 1 model loaded', () => pm.expect(body.loaded_count).to.be.at.least(1));",
            "    pm.test('Active model is valid', () => {",
            "      const ids = body.models.map(m => m.model_id);",
            "      pm.expect(ids).to.include(body.active_model_id);",
            "    });",
            "    pm.test('Models have required fields', () => {",
            "      body.models.forEach(m => {",
            "        pm.expect(m).to.have.property('model_id');",
            "        pm.expect(m).to.have.property('version');",
            "        pm.expect(m).to.have.property('is_loaded');",
            "        pm.expect(m).to.have.property('supports_tta');",
            "        pm.expect(m).to.have.property('is_active');",
            "      });",
            "    });",
            "  }",
            "} else { pm.test('Skipped (no token)', () => true); }"
          ]}}]
        },
        {
          "name": "GET /admin/fas-models — No auth (401/422)",
          "request": { "method": "GET", "url": "{{base_url}}/admin/fas-models" },
          "event": [{"listen":"test","script":{"exec":["pm.test('Rejects', () => pm.expect([401,422]).to.include(pm.response.code));"]}}]
        },
        {
          "name": "PATCH /admin/config — Switch FAS model (invalid)",
          "request": { "method": "PATCH", "url": "{{base_url}}/admin/config", "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{auth_token}}"}], "body": {"mode":"raw","raw":"{\"updates\":{\"active_fas_model\":\"nonexistent_model_xyz\"}}"} },
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.variables.get('auth_token')) {",
            "  pm.test('Rejects invalid model (400)', () => pm.expect([400,403]).to.include(pm.response.code));",
            "  if (pm.response.code === 400) {",
            "    pm.test('Has INVALID_MODEL_ID error', () => pm.expect(pm.response.json().detail.error_code).to.eql('INVALID_MODEL_ID'));",
            "  }",
            "} else { pm.test('Skipped (no token)', () => true); }"
          ]}}]
        },
        {
          "name": "GET /admin/stats — With auth",
          "request": { "method": "GET", "url": "{{base_url}}/admin/stats", "header": [{"key":"Authorization","value":"Bearer {{auth_token}}"}] },
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.variables.get('auth_token')) {",
            "  pm.test('200 or 403', () => pm.expect([200,403]).to.include(pm.response.code));",
            "} else { pm.test('Skipped (no token)', () => true); }"
          ]}}]
        },
        {
          "name": "GET /admin/automation/status — With auth",
          "request": { "method": "GET", "url": "{{base_url}}/admin/automation/status", "header": [{"key":"Authorization","value":"Bearer {{auth_token}}"}] },
          "event": [{"listen":"test","script":{"exec":[
            "if (pm.variables.get('auth_token')) {",
            "  pm.test('200 or 403', () => pm.expect([200,403]).to.include(pm.response.code));",
            "} else { pm.test('Skipped (no token)', () => true); }"
          ]}}]
        }
      ]
    }
